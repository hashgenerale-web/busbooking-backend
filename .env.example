PORT=5000
FRONTEND_URL=http://localhost:3000

# JWT — used to sign staff login tokens
JWT_SECRET=

# Supabase — find these in Project Settings → API
# SUPABASE_URL looks like: https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" secret key — NEVER expose
# this to the frontend or commit it to git. It bypasses Row Level Security.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Booking schedule
ALLOCATION_HOUR=15
ALLOCATION_MINUTE=30
REGISTRATION_OPEN_HOUR=9
REGISTRATION_CLOSE_HOUR=15
REGISTRATION_CLOSE_MINUTE=30
WITHDRAWAL_DEADLINE_HOUR=14
NEW_STAFF_PRIORITY_DAYS=30
